# ----- Added: files that should not be in version control -----

# Lock files (auto-generated, large, cause merge conflicts)
# composer.lock
# package-lock.json

# Prepros config files (local build-tool settings, not project code)
public/prepros.config
public/prepros-6.config

# Laravel log files (runtime output, can be huge)
/storage/logs/*.log

# Bootstrap cache (auto-generated by Laravel)
/bootstrap/cache/*.php

# Storage framework caches (sessions, views, compiled)
/storage/framework/cache/**
/storage/framework/sessions/**
/storage/framework/views/**
/storage/framework/testing/**

# OS-generated files
Thumbs.db
.DS_Store

# Editor / IDE extras
*.swp
*.swo
*~
